# ── Dependencies ──────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Next.js build output ──────────────────────────────────────────
/.next/
/out/
/build

# ── TypeScript ────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Environment — NEVER commit secrets ───────────────────────────
# .env.example IS committed (template with empty values only)
# Everything else must stay local
.env
.env.*
!.env.example

# ── Supabase local dev artifacts ──────────────────────────────────
supabase/.temp/
supabase/.branches/

# ── Logs ──────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Testing ───────────────────────────────────────────────────────
/coverage
/.vitest-cache

# ── OS / editor ───────────────────────────────────────────────────
.DS_Store
*.pem
.vscode/settings.json
.idea/

# ── Deployment ────────────────────────────────────────────────────
.vercel
.env*.local

# ── Google Search Console CLI ─────────────────────────────────────
# OAuth client credentials, refresh tokens, and generated search reports
# stay local and must never be committed.
/.seo/
/reports/seo/

# ── Google Analytics 4 CLI ────────────────────────────────────────
# OAuth client credentials, refresh tokens, and generated GA4 reports
# stay local and must never be committed.
/reports/analytics/

# ── Claude Code internal files ────────────────────────────────────
.claude/

# ── Encrypted credentials ─────────────────────────────────────────
*.gpg
