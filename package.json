{
  "name": "bitlink",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No test runner configured yet. See README §Testing.' && exit 0",
    "inngest:dev": "npx inngest-cli@latest dev -u http://localhost:3000/api/webhooks/inngest",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:types": "supabase gen types typescript --local > src/types/database.ts",
    "seed:stripe": "node --env-file=.env.local scripts/seed-stripe-products.mjs",
    "seo:indexnow": "node scripts/indexnow.mjs",
    "seo:gsc": "node --env-file=.env.local scripts/seo-gsc.mjs",
    "seo:gsc:auth": "npm run seo:gsc -- auth",
    "seo:gsc:properties": "npm run seo:gsc -- properties",
    "seo:gsc:sitemaps": "npm run seo:gsc -- sitemaps",
    "seo:gsc:submit-sitemap": "npm run seo:gsc -- submit-sitemap",
    "seo:gsc:queries": "npm run seo:gsc -- queries",
    "seo:gsc:pages": "npm run seo:gsc -- pages",
    "seo:gsc:inspect": "npm run seo:gsc -- inspect",
    "seo:gsc:report": "npm run seo:gsc -- report",
    "ga4": "node --env-file=.env.local scripts/ga4.mjs",
    "ga4:auth": "npm run ga4 -- auth",
    "ga4:overview": "npm run ga4 -- overview",
    "ga4:pages": "npm run ga4 -- pages",
    "ga4:sources": "npm run ga4 -- sources",
    "ga4:realtime": "npm run ga4 -- realtime",
    "ga4:ads-links": "npm run ga4 -- ads-links",
    "ga4:report": "npm run ga4 -- report"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.10",
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@types/nodemailer": "^8.0.1",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "inngest": "^3.32.4",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "nodemailer": "^9.0.0",
    "pino": "^9.7.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "googleapis": "^173.0.0",
    "pino-pretty": "^13.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
