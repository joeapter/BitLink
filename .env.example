# ─────────────────────────────────────────────────────────────────
# BitLink environment variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — NEVER commit it.
# This file (.env.example) contains only empty or safe defaults.
# ─────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# WARNING: service role key has full DB access — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────
# Use sk_test_... for local dev, sk_live_... for production
STRIPE_SECRET_KEY=
# Get from: Stripe Dashboard → Developers → Webhooks → signing secret
# Local dev: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=
# Create recurring monthly prices in Stripe, then paste the Price IDs here
STRIPE_PRICE_ISRAEL_BASIC=
STRIPE_PRICE_ISRAEL_PLUS=
STRIPE_PRICE_DATA_PLUS=
STRIPE_PRICE_UNLIMITED_DATA_PLUS=

# ── Annatel (telecom provider) ────────────────────────────────────
# Leave empty during local dev — set TELECOM_PROVIDER=mock instead.
# TODO: Obtain from Annatel business portal before enabling real provisioning.
ANNATEL_API_URL=https://business-manager.annatel.io/api
ANNATEL_API_KEY=
ANNATEL_TENANT_ID=
ANNATEL_WEBHOOK_SECRET=

# ── Inngest (durable job queue) ───────────────────────────────────
# Leave empty for local dev with `npm run inngest:dev` (no auth needed locally).
# Production: get from Inngest Cloud dashboard → Event Keys / Signing Keys.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Sentry (error monitoring) ─────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Telecom provider override ─────────────────────────────────────
# Set to 'mock' to skip all real Annatel API calls (recommended for local dev).
# Leave empty (or omit) to use Annatel with the credentials above.
TELECOM_PROVIDER=mock

# ── Logging ───────────────────────────────────────────────────────
# Options: trace | debug | info | warn | error
LOG_LEVEL=info
