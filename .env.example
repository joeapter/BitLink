# ─────────────────────────────────────────────────────────────────
# BitLink environment variables
#
# Copy this file to .env.local and fill in your values.
# .env.local is git-ignored — NEVER commit it.
# This file (.env.example) contains only empty or safe defaults.
# ─────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────
# Production should be the public origin used in Supabase Auth redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Used by Vercel Cron to authenticate scheduled API requests
CRON_SECRET=

# ── Supabase ──────────────────────────────────────────────────────
# Find these in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# WARNING: service role key has full DB access — server-side only, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────
# Use sk_test_... for local dev, sk_live_... for production
STRIPE_SECRET_KEY=
# Get from: Stripe Dashboard → Developers → Webhooks → signing secret
# Local dev: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=
# Create recurring monthly prices in Stripe, then paste the Price IDs here
STRIPE_PRICE_ISRAEL_BASIC=
STRIPE_PRICE_ISRAEL_PLUS=
STRIPE_PRICE_DATA_PLUS=
STRIPE_PRICE_UNLIMITED_DATA_PLUS=

# ── Annatel (telecom provider) ────────────────────────────────────
# Leave empty during local dev — set TELECOM_PROVIDER=mock instead.
# TODO: Obtain from Annatel business portal before enabling real provisioning.
ANNATEL_API_URL=https://business-manager.annatel.io/api
ANNATEL_API_KEY=
ANNATEL_TENANT_ID=
ANNATEL_WEBHOOK_SECRET=

# ── Inngest (durable job queue) ───────────────────────────────────
# Leave empty for local dev with `npm run inngest:dev` (no auth needed locally).
# Production: get from Inngest Cloud dashboard → Event Keys / Signing Keys.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Sentry (error monitoring) ─────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── Telecom provider override ─────────────────────────────────────
# Set to 'mock' to skip all real Annatel API calls (recommended for local dev).
# Leave empty (or omit) to use Annatel with the credentials above.
TELECOM_PROVIDER=mock

# ── Email (Migadu SMTP) ───────────────────────────────────────────
SMTP_HOST=smtp.migadu.com
SMTP_PORT=465
SMTP_USER=orders@bitlink.co.il
# Set SMTP_PASSWORD in Vercel dashboard — never commit the real value
SMTP_PASSWORD=
SMTP_FROM=BitLink <orders@bitlink.co.il>

# ── CDR ingest shared secret ─────────────────────────────────────
# Must match the secret set on the VPS relay script.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CDRS_INGEST_SECRET=

# ── Annatel CDR delivery (FTP) ────────────────────────────────────
# Ask Annatel for FTP credentials and CDR file format before enabling.
ANNATEL_FTP_HOST=
ANNATEL_FTP_PORT=21
ANNATEL_FTP_USER=
ANNATEL_FTP_PASS=
ANNATEL_FTP_PATH=/cdrs
# Set to 'true' if Annatel requires FTPS
ANNATEL_FTP_SECURE=false

# ── WhatsApp Cloud API (Phase 2) ─────────────────────────────────
# Leave all empty for Phase 1 (manual wa.me links — no Meta account needed).
# Set these when you have a verified Meta WhatsApp Business account.
# See: src/lib/support/channels/whatsappCloudApi.ts for full setup steps.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ── Logging ───────────────────────────────────────────────────────
# Options: trace | debug | info | warn | error
LOG_LEVEL=info

# ── Google Search Console CLI ─────────────────────────────────────
# The URL-prefix property must match the property verified in Search Console.
# For a Domain property, use: sc-domain:bitlink.co.il
GSC_SITE_URL=https://www.bitlink.co.il/
# Recommended: gcloud Application Default Credentials. Run `npm run seo:gsc:auth` once.
# Optional fallback: set GSC_AUTH_MODE=oauth to use the Desktop OAuth files below.
GSC_AUTH_MODE=gcloud
# Both paths are git-ignored; never commit credentials or refresh tokens.
GSC_OAUTH_CLIENT_FILE=.seo/google-oauth-client.json
GSC_OAUTH_TOKEN_FILE=.seo/google-oauth-token.json
